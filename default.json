{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":semanticCommits"
  ],
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "timezone": "America/Los_Angeles",
  "schedule": [
    "* 5-8 * * 1-5"
  ],
  "packageRules": [
    {
      "description": "Auto-merge all update types when CI passes (safety via minimumReleaseAge + CI gate)",
      "matchUpdateTypes": [
        "patch",
        "minor",
        "major",
        "digest",
        "pinDigest",
        "pin"
      ],
      "automerge": true
    },
    {
      "description": "Pin Docker tags to immutable digests",
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "pinDigests": true
    },
    {
      "description": "Lockfile maintenance unaffected by minimumReleaseAge (package-manager-controlled)",
      "matchUpdateTypes": [
        "lockFileMaintenance"
      ],
      "minimumReleaseAge": null
    },
    {
      "description": "Package replacements unaffected by minimumReleaseAge (Renovate limitation - issue #39400)",
      "matchUpdateTypes": [
        "replacement"
      ],
      "minimumReleaseAge": null
    },
    {
      "description": "Pin update types do not wire in release age (Renovate limitation - issue #40288). Matches security:minimumReleaseAgeNpm preset.",
      "matchUpdateTypes": [
        "pin",
        "pinDigest"
      ],
      "minimumReleaseAge": null
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["ansible/runtime-versions\\.ya?ml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+\\w+_version:\\s+[\"']?(?<currentValue>.+?)[\"']?$"
      ]
    }
  ],
  "prConcurrentLimit": 5,
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "schedule": [
      "at any time"
    ],
    "minimumReleaseAge": null
  },
  "prCreation": "immediate"
}
