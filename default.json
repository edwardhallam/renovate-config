{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":semanticCommits"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "pinDigests": true
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchCategories": [
        "security"
      ],
      "automerge": true,
      "automergeType": "pr",
      "schedule": [
        "at any time"
      ]
    }
  ],
  "prConcurrentLimit": 5
}
